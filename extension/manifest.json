{
    "manifest_version": 3,
    "name": "VidNote — 智能视频笔记",
    "description": "在 YouTube 上边看视频边做笔记，支持时间戳跳转、高光标记和 AI 自动总结",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        },
        "default_title": "VidNote"
    },
    "side_panel": {
        "default_path": "sidepanel/panel.html"
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://youtube.com/*",
                "https://m.youtube.com/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "activeTab",
        "tabs",
        "sidePanel"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://api.openai.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "https://www.youtube.com/*"
            ]
        }
    ]
}